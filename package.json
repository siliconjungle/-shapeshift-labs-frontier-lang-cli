{
  "name": "@shapeshift-labs/frontier-lang-cli",
  "version": "0.1.1",
  "description": "Command line interface for parsing, checking, hashing, and emitting Frontier Lang projects.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "npm run build && node test/smoke.mjs",
    "prepare": "npm run build",
    "prepack": "npm test"
  },
  "keywords": [
    "frontier",
    "semantic-merge",
    "patch",
    "replay",
    "compiler"
  ],
  "author": "ShapeShift Labs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siliconjungle/-shapeshift-labs-frontier-lang-cli.git"
  },
  "bugs": {
    "url": "https://github.com/siliconjungle/-shapeshift-labs-frontier-lang-cli/issues"
  },
  "homepage": "https://github.com/siliconjungle/-shapeshift-labs-frontier-lang-cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@shapeshift-labs/frontier-lang-kernel": "^0.1.1",
    "@shapeshift-labs/frontier-lang-parser": "^0.1.0",
    "@shapeshift-labs/frontier-lang-checker": "^0.1.0",
    "@shapeshift-labs/frontier-lang-typescript": "^0.1.0"
  },
  "bin": {
    "frontier-lang": "dist/index.js"
  }
}
